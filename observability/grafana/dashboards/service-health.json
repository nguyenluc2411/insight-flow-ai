{
  "uid": "insight-service-health",
  "title": "Service Health Overview",
  "description": "HTTP request rate, error rate, and latency for all Insight Flow AI services",
  "tags": ["insight-flow", "health"],
  "timezone": "Asia/Ho_Chi_Minh",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate — All Services (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"auth-service|catalog-service|sales-service|billing-service|integration-service|dashboard-bff|notification-service\"}[1m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Error Rate — 5xx (% of requests)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"auth-service|catalog-service|sales-service|billing-service|integration-service|dashboard-bff|notification-service\",status=~\"5..\"}[1m])) / sum by (job) (rate(http_server_requests_seconds_count{job=~\"auth-service|catalog-service|sales-service|billing-service|integration-service|dashboard-bff|notification-service\"}[1m])) * 100",
          "legendFormat": "{{job}} error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "P99 Latency — All Services (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_server_requests_seconds_bucket{job=~\"auth-service|catalog-service|sales-service|billing-service|integration-service|dashboard-bff|notification-service\"}[1m]))) * 1000",
          "legendFormat": "{{job}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 4,
      "title": "API Gateway — Request Rate by Route (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"api-gateway\"}[1m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "DB Connection Pool — Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{job=~\"auth-service|catalog-service|sales-service|billing-service|integration-service|notification-service\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "JVM Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_used_bytes{job=~\"auth-service|catalog-service|sales-service|billing-service|integration-service|dashboard-bff|notification-service\",area=\"heap\"} / 1024 / 1024",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "megabytes" }
      }
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag — All Services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kafka_consumer_fetch_manager_records_lag{job=~\"catalog-service|sales-service|billing-service|ml-service|notification-service\"}",
          "legendFormat": "{{job}} / {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    }
  ]
}
