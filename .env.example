# ============================================================
# insight-flow-ai — .env.example
# Template để chia sẻ qua Git. Copy thành .env và điền giá trị thật.
#   cp .env.example .env
#
# QUAN TRỌNG — 2 chế độ chạy:
#
# 1. Local dev (services chạy trực tiếp trên host, chỉ infra trong Docker):
#      docker-compose -f infrastructure/docker/docker-compose.yml --env-file .env up -d
#    Dùng giá trị mặc định trong file này (localhost, port 5433, 9092).
#
# 2. Full Docker (tất cả trong container):
#      docker-compose \
#        -f infrastructure/docker/docker-compose.yml \
#        -f infrastructure/docker/docker-compose.services.yml \
#        --env-file .env up -d
#    docker-compose.services.yml tự override POSTGRES_HOST=postgres,
#    POSTGRES_PORT=5432, KAFKA_BOOTSTRAP_SERVERS=kafka:29092, v.v.
#    File .env vẫn dùng cho các secrets (USER, PASSWORD, JWT_SECRET, ...).
# ============================================================

# --- Shared: PostgreSQL ---
# Local dev: host=localhost, port=5433 (mapped từ container)
# Full Docker: docker-compose.services.yml override host=postgres, port=5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=insightflow
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me

# --- Per-service databases (database-per-service pattern) ---
# init.sql creates these automatically on first Docker run.
AUTH_DB_NAME=insightflow_auth
CATALOG_DB_NAME=insightflow_catalog
SALES_DB_NAME=insightflow_sales
INTEGRATION_DB_NAME=insightflow_integration
NOTIFICATION_DB_NAME=insightflow_notification
ML_DB_NAME=insightflow_ml

# --- Shared: Kafka ---
# Local dev: localhost:9092 (EXTERNAL listener)
# Full Docker: docker-compose.services.yml override kafka:29092 (INTERNAL listener)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Shared: Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Shared: Eureka discovery ---
EUREKA_URL=http://localhost:8761/eureka/

# --- Shared: Spring Cloud Config ---
CONFIG_SERVER_URL=http://localhost:8888
# Local dev: đường dẫn tuyệt đối đến config-repo/ trên máy bạn.
# Full Docker: docker-compose.services.yml override CONFIG_REPO_PATH=/config-repo (volume mount).
CONFIG_REPO_PATH=D:/SU26/EXE201/insight-flow-ai/config-repo

# --- Shared: JWT (must match between api-gateway and auth-service) ---
# Generate with: openssl rand -base64 32
JWT_SECRET=generate_with_openssl_rand_base64_32

# --- api-gateway ---
GATEWAY_CORS_ALLOWED_ORIGIN=http://localhost:3000

# --- notification-service (SMTP) ---
# Dev: point to local MailHog (port 8025 UI, 1025 SMTP)
#   docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@insightflow.ai

# --- integration-service ---
# KiotViet developer app credentials (register at https://id.kiotviet.vn)
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
# Retailer code shown in KiotViet portal
# KIOTVIET_RETAILER_NAME=   (stored per-connector in DB)
# Jasypt encryption key for POS credentials stored in DB (min 16 chars)
JASYPT_PASSWORD=dev-encrypt-key-change-in-prod!!

# --- MinIO (object storage: ML models + images) ---
# Console UI: http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_prod

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=change_me_in_prod

# --- pgAdmin (docker-compose only) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me
